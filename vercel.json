{
  "version": 2,
  "regions": ["bom1"],
  "builds": [
    { "src": "next.config.js", "use": "@vercel/next" }
  ],
  "functions": {
    "app/api/ai/**": { "maxDuration": 60 },
    "app/api/crop-recommender/**": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/docs", "dest": "/docs" },
    { "src": "/openapi.json", "dest": "/openapi.json" },
    { "src": "/health", "dest": "/health" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/ml/(.*)", "dest": "/ml/$1" }
  ]
}
