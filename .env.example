# =============================================================================
# MultiSow Environment Configuration
# Copy this to .env and fill in real values for production
# =============================================================================

# --- Core ---
MULTISOW_ENVIRONMENT=development
MULTISOW_DATABASE_URL=sqlite:///./sql_app.db

# --- InfluxDB 2.x (IoT sensor data) ---
MULTISOW_INFLUXDB_URL=http://localhost:8086
MULTISOW_INFLUXDB_TOKEN=multisow-dev-token
MULTISOW_INFLUXDB_ORG=multisow
MULTISOW_INFLUXDB_BUCKET=sensor_data

# --- PostgreSQL / PostGIS (optional, for geospatial) ---
MULTISOW_POSTGRES_URL=

# --- Redis (Celery broker) ---
MULTISOW_REDIS_URL=redis://localhost:6379/0

# --- MLflow ---
MULTISOW_MLFLOW_TRACKING_URI=http://localhost:5000

# --- ML Model ---
MULTISOW_ML_MODEL_PATH=./data/models
MULTISOW_FEATURE_STORE_PATH=./data/feature_store
MULTISOW_FOHEM_BOOTSTRAP_ON_STARTUP=true
MULTISOW_FOHEM_AUTO_RETRAIN_THRESHOLD=50

# --- Docker Compose ---
INFLUXDB_TOKEN=multisow-dev-token

# --- Frontend Deployment (Vercel/Standalone) ---
BACKEND_URL=http://localhost:8001
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_ENABLE_3D=true
NEXT_PUBLIC_ENABLE_ML=true

# Comma-separated list of allowed CORS origins (used by FastAPI backend)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Anthropic Claude API Key
# Get your key at: https://console.anthropic.com/settings/keys
# NEVER commit your actual key — this file is a template only
ANTHROPIC_API_KEY=API KEY GOES HERE
# NLP Feature Flags
NLP_ENABLED=true
NLP_MODEL=claude-opus-4-5
NLP_MAX_TOKENS=400
NLP_LANGUAGE_DEFAULT=english
