{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/custom-model/layout,_N_T_/custom-model/page,_N_T_/custom-model"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/custom-model/__PAGE__",
    "/custom-model",
    "/_index",
    "/_head"
  ]
}